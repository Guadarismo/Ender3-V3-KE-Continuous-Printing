; --- END PIECE 1 ---

; =======================================
; PIECE ITERATION 2
; =======================================

; --- SAFE PUSH ROUTINE ---
M117 Cooling bed to 35C...
M140 S0 ; Bed off
M104 S150 ; Nozzle standby to stop oozing
G1 X110 Y200 F5000 ; Move away during cooling
M190 R35 ; Wait for bed to cool to 35C (piece detached)
M117 Ejecting peça...
G90 ; Absolute coordinates
G1 Z50 F3000 ; Lift head 5cm
G1 Y150 F5000 ; Bed forward (puts piece behind nozzle line)
G1 X110 F5000 ; Center nozzle on piece (X)
G1 Z5 F3000   ; Lower head to 0.5cm height
G1 Y0 F1500   ; Bed backward (Nozzle hits piece and pushes it off front)
G1 Z50 F3000  ; Safety lift
; --- END SAFE PUSH ROUTINE ---
M220 S100 ;Reset Feedrate 
M221 S100 ;Reset Flowrate 
 
M140 S60 ;Set final bed temp  
G28 ;Home 
 
G92 E0 ;Reset Extruder 
G1 Z2.0 F3000 ;Move Z Axis up 
M104 S240 ;Set final nozzle temp  
G1 X-2.0 Y20 Z0.28 F5000.0 ;Move to start position 
M190 S60 ;Wait for bed temp to stabilize  
M109 S240 ;Wait for nozzle temp to stabilize  
G1 X-2.0 Y145.0 Z0.28 F1500.0 E15 ;Draw the first line 
; [Purge line skipped for Iteration 2]
G1 E-1.0000 F1800 ;Retract a bit 
M73 P1 R11
G1 Z2.0 F3000 ;Move Z Axis up 
G1 E0.0000 F1800
G90
G21
M83 ; use relative distances for extrusion
; filament start gcode
SET_PRESSURE_ADVANCE ADVANCE=0.048; Override pressure advance value
G1 E-.5 F1800
G1 Z.2 F18000
M106 S0
